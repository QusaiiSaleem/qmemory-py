# SurrealDB — local development
QMEMORY_SURREAL_URL=ws://localhost:8000
QMEMORY_SURREAL_USER=root
QMEMORY_SURREAL_PASS=root
QMEMORY_SURREAL_NS=qmemory
QMEMORY_SURREAL_DB=main

# SurrealDB — Railway deployment (set these in Railway dashboard, not here)
# For the SurrealDB SERVICE (surrealdb/ folder):
#   PORT=8000
#   SURREAL_USER=root
#   SURREAL_PASS=<generate strong password in Railway>
#   SURREAL_LOG=info
#
# For the APP SERVICE (connects to DB):
#   QMEMORY_SURREAL_URL=ws://surrealdb.railway.internal:8000   (internal, free)
#   QMEMORY_SURREAL_PASS=<same password as SURREAL_PASS above>

# LLM
ANTHROPIC_API_KEY=sk-...

# Embeddings
VOYAGE_API_KEY=pa-...
